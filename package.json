{
    "name": "@rapidrest/react",
    "version": "0.1.0",
    "description": "A library for serving React based content from a RapidREST server.",
    "repository": "https://github.com/rapidrest/react.git",
    "author": "RapidREST <rapidrests@gmail.com>",
    "license": "MIT",
    "contributors": [
        "Jean-Philippe Steinmetz"
    ],
    "scripts": {
        "build": "yarn lint && rimraf dist && tsc",
        "deploy-docs": "ts-node tools/gh-pages-publish",
        "docs": "typedoc --plugin typedoc-plugin-markdown --out docs/reference src",
        "lint": "eslint ./src ./test",
        "local-audit": "yarn install && yarn npm audit -A -R \"$@\"",
        "checkup": "yarn dlx @yarnpkg/doctor \"$@\"",
        "dependency-check": "yarn dlx depcheck \"$@\"",
        "report-coverage": "cat ./coverage/lcov.info | coveralls",
        "bench": "tsx bench/index.ts",
        "bench:baseline": "yarn bench 2>&1 | tee bench/baseline.txt",
        "test": "vitest run",
        "test:prod": "npm run lint && vitest run --coverage",
        "test:watch": "vitest",
        "postversion": "git push && git push --tags"
    },
    "peerDependencies": {
        "@rapidrest/core": "1.x",
        "@rapidrest/service-core": "1.x",
        "react": "19.x",
        "react-dom": "19.x"
    },
    "devDependencies": {
        "@rapidrest/core": "^1.3.0",
        "@rapidrest/service-core": "1.0.0-rc.10",
        "@swc/core": "^1.15.41",
        "@types/node": "^25.9.2",
        "@typescript-eslint/eslint-plugin": "^8.61.0",
        "@typescript-eslint/parser": "^8.61.0",
        "@vitest/coverage-v8": "^4.1.8",
        "eslint": "^10.4.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-jsdoc": "^63.0.2",
        "globals": "^17.6.0",
        "ioredis": "^5.11.1",
        "lodash-es": "^4.18.1",
        "mongodb": "^7.4.0",
        "nconf": "^0.13.0",
        "openapi3-ts": "^4.6.0",
        "prom-client": "^15.1.3",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "reflect-metadata": "^0.2.2",
        "rimraf": "^6.1.3",
        "ts-node": "^10.9.2",
        "tsx": "^4.19.3",
        "typedoc": "^0.28.19",
        "typedoc-plugin-markdown": "^4.12.0",
        "typeorm": "^1.0.0",
        "typescript": "^6.0.3",
        "unplugin-swc": "^1.5.9",
        "vitest": "^4.1.8",
        "winston": "^3.19.0"
    },
    "resolutions": {
        "cross-spawn": "^7.0.5"
    },
    "packageManager": "yarn@4.5.3",
    "engines": {
        "node": ">=24.0.0"
    },
    "publishConfig": {
        "registry": "https://registry.npmjs.org/"
    },
    "type": "module",
    "main": "dist/lib/index.js",
    "exports": {
        ".": {
            "import": "./dist/lib/index.js",
            "types": "./dist/types/index.d.ts"
        }
    },
    "typings": "dist/types/index.d.ts",
    "files": [
        "dist",
        "docs"
    ]
}
