{
    "compilerOptions": {
        "jsx": "react",
        "moduleResolution": "NodeNext",
        "target": "ES2020",
        "module": "NodeNext",
        "strict": true,
        "sourceMap": true,
        "declaration": true,
        "allowSyntheticDefaultImports": true,
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "noImplicitAny": false,
        "rootDir": "src",
        "declarationDir": "dist/types",
        "outDir": "dist/lib"
    },
    "include": ["src"]
}
